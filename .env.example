# Database
DATABASE_URL=sqlite:///data/auction.db

# Data storage
DATA_DIR=data

# Logging
LOG_LEVEL=INFO

# API
API_PORT=8000
API_HOST=0.0.0.0

# Auction sources
AUCTIONET_BASE_URL=https://auctionet.com
AUCTIONET_RATE_LIMIT_REQUESTS=10
AUCTIONET_RATE_LIMIT_PERIOD=60

# Job scheduling
BROAD_CRAWL_INTERVAL_MINUTES=60
WATCHLIST_REFRESH_INTERVAL_MINUTES=15
ENDING_SOON_REFRESH_INTERVAL_MINUTES=5
ENDING_SOON_THRESHOLD_HOURS=2
ENRICHMENT_QUEUE_INTERVAL_MINUTES=10

# Enrichment
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Feature flags
ENABLE_IMAGE_DOWNLOAD=true
ENABLE_ENRICHMENT=true
ENABLE_SCHEDULER=true
